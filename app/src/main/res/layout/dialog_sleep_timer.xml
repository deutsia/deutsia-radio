<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Enable/Disable Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_sleep_timer_enable"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/sleepTimerSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Duration Display -->
        <TextView
            android:id="@+id/sleepTimerDurationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textSize="32sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            tools:text="30 min" />

        <!-- Hour + Minute pickers -->
        <LinearLayout
            android:id="@+id/sleepTimerPickersContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <NumberPicker
                    android:id="@+id/sleepTimerHoursPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:descendantFocusability="blocksDescendants" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_sleep_timer_hours_label"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="20dp"
                android:text=":"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <NumberPicker
                    android:id="@+id/sleepTimerMinutesPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:descendantFocusability="blocksDescendants" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_sleep_timer_minutes_label"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

        <!-- Quick Preset Buttons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_sleep_timer_presets"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- Row 1: Minutes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset10min"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="10m"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset15min"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="15m"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset30min"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="30m"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset45min"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="45m"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <!-- Row 2: Hours -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset1hour"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="1h"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset2hours"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="2h"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset3hours"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="3h"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset4hours"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="4h"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
